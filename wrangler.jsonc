{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "musicmp3",
  "compatibility_date": "2026-06-07",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      ".git/**",
      ".wrangler/**",
      "node_modules/**",
      "*.jsonc"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
